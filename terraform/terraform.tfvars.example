# Copy to terraform.tfvars (never commit terraform.tfvars — it is gitignored)
# These values are also passed as TF_VAR_* secrets in the GitHub Actions workflow.

aws_region   = "us-east-1"
environment  = "production"
instance_type = "t3.small"

# Public URL — must match your DNS record pointing to the Elastic IP
ghost_url = "https://blog.example.com"

# Docker Hub image built by the docker-build.yml pipeline
ghost_image = "yourdockerhubuser/shehujp-blog:latest"

# Optional: restrict SSH to your IP. Leave empty to use SSM only (recommended).
allowed_ssh_cidr = ""   # e.g. "203.0.113.10/32"

root_volume_size_gb = 20
data_volume_size_gb = 30
